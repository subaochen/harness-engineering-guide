{
  "version": "1.0",
  "created": "2026-04-21",
  "description": "事务自动重试策略配置",
  
  "max_retries": 2,
  "retry_delay_seconds": 60,
  "exponential_backoff": true,
  "backoff_multiplier": 2,
  
  "retryable_errors": [
    "timeout",
    "network_error",
    "api_rate_limit",
    "temporary_unavailable",
    "session_expired",
    "model_overloaded"
  ],
  
  "non_retryable_errors": [
    "invalid_input",
    "permission_denied",
    "resource_not_found",
    "authentication_failed",
    "quota_exceeded"
  ],
  
  "fallback_strategy": {
    "enabled": true,
    "fallback_order": ["qingbao", "wenan", "jiaoxue"],
    "max_fallback_depth": 2
  },
  
  "circuit_breaker": {
    "enabled": true,
    "failure_threshold": 3,
    "recovery_timeout_seconds": 300
  }
}
